{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./lib.json",
  "compilerOptions": {
    "experimentalDecorators": true,

    "jsx": "preserve",
    "jsxFactory": "h",
    "jsxFragmentFactory": "Fragment",

    "types": ["vite/client", "vue"]
  },
  "vueCompilerOptions": {
    "skipTemplateCodegen": true
  },
  "include": [
    "${configDir}/src/**/*.ts",
    "${configDir}/src/**/*.d.ts",
    "${configDir}/src/**/*.tsx",
    "${configDir}/src/**/*.vue"
  ]
}
